rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}